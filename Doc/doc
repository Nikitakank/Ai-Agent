(from strands import Agent 
from strands.models.ollama import OllamaModel 
 #By default it runs Amazon bedrock in the Background.(Amazon bedrock it the service form aws which gen ai can created and in  background work with LLM's)
ollamaModel_model=OllamaModel(
    host="http://localhost:11434", 
    model_id="llama3.2:1b"           
)
system_prompt = "You are a respectful agent. You give answers in a kind and humble way.""You can use correct data sources to give outputs." 
agent = Agent(model=ollamaModel_model, system_prompt=system_prompt)
 
# user_input = input("YOU:")
agent("hello, how im i ")
)
